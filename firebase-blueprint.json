{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a system user with authentication and role-based access controls.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Super Admin", "Head Office", "Project Manager", "Site Engineer", "Supervisor", "Time Keeper", "Team Leader", "Gang Chief", "Worker", "Store Manager", "HR Manager", "Finance Manager"] },
        "status": { "type": "string", "enum": ["Active", "Suspended"] },
        "createdAt": { "type": "string" },
        "phoneNumber": { "type": "string" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents an enterprise construction project master document.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "budget": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Planning", "Active", "Completed", "On Hold"] },
        "managerId": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Site": {
      "title": "Site",
      "description": "Represents a specific physical site under a project division.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "gpsCoordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["id", "projectId", "name"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Detailed staff/employee profile record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "joinedDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "role", "status"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "Represents a single daily check-in/out session for a worker, including biometric validation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "date": { "type": "string" },
        "checkIn": { "type": "string" },
        "checkOut": { "type": "string" },
        "method": { "type": "string", "enum": ["Fingerprint", "FaceID", "Manual", "RFID"] },
        "workingHours": { "type": "number" },
        "overtime": { "type": "number" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Late", "Leave", "Holiday"] }
      },
      "required": ["id", "workerId", "workerName", "date", "status"]
    },
    "Payroll": {
      "title": "Payroll",
      "description": "Represents monthly payroll calculations, basic pay, deductions, and overtime totals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "month": { "type": "string" },
        "basicSalary": { "type": "number" },
        "overtimePay": { "type": "number" },
        "allowances": { "type": "number" },
        "deductions": { "type": "number" },
        "netPayable": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Approved", "Paid"] }
      },
      "required": ["id", "employeeId", "month", "netPayable", "status"]
    },
    "Material": {
      "title": "Material",
      "description": "Represents cataloged build materials with global specifications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "name", "unit"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Represents active inventory balances, quantities, and reorder levels across sites.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "siteId": { "type": "string" },
        "materialId": { "type": "string" },
        "quantity": { "type": "number" },
        "reorderLevel": { "type": "number" },
        "lastUpdated": { "type": "string" }
      },
      "required": ["id", "siteId", "materialId", "quantity"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Represents heavy machinery and asset lists deployed at sites.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "serialNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "In Use", "Maintenance", "Broken"] },
        "assignedSiteId": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Fleet vehicles and transport dispatch assets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plateNumber": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["Operational", "In Service", "Under Repair"] }
      },
      "required": ["id", "plateNumber", "status"]
    },
    "FormworkPanel": {
      "title": "FormworkPanel",
      "description": "Formwork systems inventory, tracking casting steel panel installations and stripping cycles.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "dimensions": { "type": "string" },
        "totalQty": { "type": "number" },
        "deployedQty": { "type": "number" }
      },
      "required": ["id", "type", "totalQty"]
    },
    "CADFile": {
      "title": "CADFile",
      "description": "Represents blueprinted engineering CAD drawings and revision hashes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "version": { "type": "string" },
        "fileUrl": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string" }
      },
      "required": ["id", "title", "version", "fileUrl"]
    },
    "DailyReport": {
      "title": "DailyReport",
      "description": "Unified site supervisor daily progress journal entries.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "siteId": { "type": "string" },
        "date": { "type": "string" },
        "progressHighlights": { "type": "string" },
        "incidents": { "type": "string" },
        "submittedBy": { "type": "string" }
      },
      "required": ["id", "siteId", "date", "submittedBy"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time critical systems alert payload.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "recipientId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "recipientId", "title", "message", "read", "timestamp"]
    },
    "Approval": {
      "title": "Approval",
      "description": "Multi-stage enterprise ERP approval workflows.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Purchase Request", "Overtime Approval", "Contract Signing", "Leave Request"] },
        "requesterId": { "type": "string" },
        "approverId": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "details": { "type": "string" },
        "amount": { "type": "number" }
      },
      "required": ["id", "type", "requesterId", "status"]
    },
    "Expense": {
      "title": "Expense",
      "description": "On-site and administrative cash flow outflows.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Paid"] },
        "date": { "type": "string" }
      },
      "required": ["id", "projectId", "category", "amount", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Client billing and billing receivables registers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Paid", "Overdue"] },
        "dueDate": { "type": "string" }
      },
      "required": ["id", "clientName", "amount", "status"]
    },
    "Contract": {
      "title": "Contract",
      "description": "Enterprise subcontractors and procurement vendor contracts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "party": { "type": "string" },
        "value": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Completed", "Terminated"] }
      },
      "required": ["id", "title", "party", "value", "status"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Continuous compliance security audit trails.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "role": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["id", "timestamp", "userId", "userName", "role", "action", "details"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "System access user roles mapping registry."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Master registered projects."
    },
    "/sites/{siteId}": {
      "schema": "Site",
      "description": "Construction site registries."
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Master employee records."
    },
    "/attendance/{attendanceId}": {
      "schema": "AttendanceRecord",
      "description": "Secured site attendance checking logs."
    },
    "/payroll/{payrollId}": {
      "schema": "Payroll",
      "description": "Payroll records."
    },
    "/materials/{materialId}": {
      "schema": "Material",
      "description": "Material spec files."
    },
    "/inventory/{inventoryId}": {
      "schema": "Inventory",
      "description": "Material quantities deployed on site."
    },
    "/equipment/{equipmentId}": {
      "schema": "Equipment",
      "description": "Site heavy machinery inventory lists."
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Fleet vehicles and transport dispatch assets."
    },
    "/formworkPanels/{panelId}": {
      "schema": "FormworkPanel",
      "description": "Steel formwork panels state inventory."
    },
    "/cadFiles/{cadId}": {
      "schema": "CADFile",
      "description": "Engineering CAD drawings and schema specs."
    },
    "/dailyReports/{reportId}": {
      "schema": "DailyReport",
      "description": "Unified site supervisor daily progress journal entries."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Real-time system alarms."
    },
    "/approvals/{approvalId}": {
      "schema": "Approval",
      "description": "Multi-stage corporate ERP workflows."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Active site cash flow spend logbook."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Billing invoicing tracking logs."
    },
    "/contracts/{contractId}": {
      "schema": "Contract",
      "description": "Subcontractors and procurement contract specs."
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Immutable security tracking audit logs."
    }
  }
}
