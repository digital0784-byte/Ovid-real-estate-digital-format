rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default safety net: Lock down all documents
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // SECURITY UTILITIES & HELPER FUNCTIONS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    // Retrieve active user profile and roles from the secure users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    // Role membership predicates
    function hasRole(role) {
      return isSignedIn() && getUserRole() == role;
    }

    function isSuperAdmin() {
      return hasRole('Super Admin');
    }

    function isHeadOffice() {
      return hasRole('Head Office');
    }

    function isProjectManager() {
      return hasRole('Project Manager');
    }

    function isSiteEngineer() {
      return hasRole('Site Engineer');
    }

    function isSupervisor() {
      return hasRole('Supervisor');
    }

    function isTimeKeeper() {
      return hasRole('Time Keeper');
    }

    function isStoreManager() {
      return hasRole('Store Manager');
    }

    function isHRManager() {
      return hasRole('HR Manager');
    }

    function isFinanceManager() {
      return hasRole('Finance Manager');
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ID validation sanity check
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ==========================================
    // MODULE-SPECIFIC RULE MATCHING
    // ==========================================

    // 1. Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSuperAdmin() || isHeadOffice() || isOwner(userId);
      allow delete: if isSuperAdmin();
    }

    // 2. Projects & Sites
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isProjectManager();
    }
    match /sites/{siteId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isProjectManager();
    }

    // 3. Employees
    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isHRManager();
    }

    // 4. Attendance (Requires Time Keeper, Supervisor or higher)
    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isTimeKeeper() || isSupervisor() || isProjectManager();
    }

    // 5. Payroll
    match /payroll/{payrollId} {
      allow read: if isSuperAdmin() || isHeadOffice() || isFinanceManager() || isHRManager() || (isSignedIn() && incoming().employeeId == request.auth.uid);
      allow write: if isSuperAdmin() || isHeadOffice() || isFinanceManager();
    }

    // 6. Materials & Inventory
    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isStoreManager() || isProjectManager();
    }
    match /inventory/{inventoryId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isStoreManager() || isProjectManager();
    }

    // 7. Equipment & Vehicles
    match /equipment/{equipmentId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isStoreManager() || isProjectManager();
    }
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isStoreManager() || isProjectManager();
    }

    // 8. Formwork Panels
    match /formworkPanels/{panelId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isSiteEngineer() || isSupervisor() || isProjectManager();
    }

    // 9. CAD Files
    match /cadFiles/{cadId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isSiteEngineer() || isProjectManager();
    }

    // 10. Daily Reports
    match /dailyReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isSiteEngineer() || isSupervisor() || isProjectManager();
    }

    // 11. Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isHeadOffice() || isProjectManager() || isHRManager() || isFinanceManager();
    }

    // 12. Approvals
    match /approvals/{approvalId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || isHeadOffice() || isProjectManager() || isFinanceManager() || isHRManager();
      allow delete: if isSuperAdmin();
    }

    // 13. Expenses, Invoices, & Contracts
    match /expenses/{expenseId} {
      allow read: if isSuperAdmin() || isHeadOffice() || isFinanceManager() || isProjectManager();
      allow write: if isSuperAdmin() || isHeadOffice() || isFinanceManager();
    }
    match /invoices/{invoiceId} {
      allow read: if isSuperAdmin() || isHeadOffice() || isFinanceManager() || isProjectManager();
      allow write: if isSuperAdmin() || isHeadOffice() || isFinanceManager();
    }
    match /contracts/{contractId} {
      allow read: if isSuperAdmin() || isHeadOffice() || isFinanceManager() || isProjectManager();
      allow write: if isSuperAdmin() || isHeadOffice() || isFinanceManager();
    }

    // 14. Audit Logs (Append-Only and strictly Immutable once written)
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin() || isHeadOffice() || isHRManager();
      allow create: if isSignedIn() && isValidId(logId);
      allow update, delete: if false;
    }
  }
}
